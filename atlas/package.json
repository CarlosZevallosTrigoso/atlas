{
  "name": "atlas",
  "version": "0.1.0",
  "description": "Plataforma personal de archivo y exploración multimodal",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public --project-name=atlas",
    "db:migrate:local": "wrangler d1 execute atlas-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute atlas-db --remote --file=migrations/0001_initial.sql",
    "db:query:local": "wrangler d1 execute atlas-db --local --command",
    "db:query:remote": "wrangler d1 execute atlas-db --remote --command"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "typescript": "^5.9.3",
    "wrangler": "^3.99.0"
  }
}
